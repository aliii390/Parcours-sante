{% extends 'base.html.twig' %}

{% block title %}Tableau de bord — Parcours Santé{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 flex flex-col pb-20 md:pb-0">



  <!-- ===== MAIN ===== -->
  <main class="flex-1 max-w-7xl w-full mx-auto px-4 md:px-8 py-8">

    <!-- Greeting -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-1">Bonjour, {{app.user.prenom}}</h1>
      <p class="text-gray-500 text-sm md:text-base">Voici un aperçu de votre santé pour aujourd'hui, 14 Mars 2026.</p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- ===== COLONNE GAUCHE (RDV + Journal) ===== -->
      <div class="lg:col-span-2 space-y-6">

        <!-- PROCHAINS RENDEZ-VOUS -->
        <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 md:p-6">
          <div class="flex items-center justify-between mb-5">
            <h2 class="flex items-center gap-2 text-base font-bold text-gray-900">
              <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              Prochains rendez-vous
            </h2>
            <a href="{{path('app_rendez_vous')}}" class="text-sm font-medium text-gray-900 underline hover:text-blue-600">Voir tout</a>
          </div>
 {% for rdv in rendezVous %}
          <div class="space-y-3">
            <!-- RDV 1 -->
           
            <div class="flex items-center gap-4 p-3 rounded-xl hover:bg-slate-50 transition-colors">
              <div class="flex flex-col items-center justify-center w-12 h-14 bg-slate-100 rounded-lg flex-shrink-0">
                <span class="text-[10px] font-semibold text-gray-400 uppercase">Mar</span>
                <span class="text-lg font-bold text-gray-900 leading-none">15</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-bold text-gray-900 text-sm">{{rdv.titre}}</p>
                <p class="text-xs text-gray-500">{{rdv.category.nom}} • {{rdv.medecin}}</p>
              </div>
              <div class="text-right hidden sm:block">
                <p class="text-sm font-bold text-gray-900">{{rdv.date|date('H:i')}}</p>
                <p class="text-xs text-gray-400">Cabinet Médical</p>
              </div>
             
            </div>
            {% endfor %}

            
         
        </section>

        <!-- DERNIÈRE ENTRÉE JOURNAL -->
        <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 md:p-6">
          <div class="flex items-center justify-between mb-5">
            <h2 class="flex items-center gap-2 text-base font-bold text-gray-900">
              <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
              Dernière entrée du journal
            </h2>
            <a href="#" class="bg-gray-900 hover:bg-gray-800 text-white text-xs font-semibold px-4 py-2 rounded-lg transition-colors">Nouvelle entrée</a>
          </div>

          <div class="bg-slate-50 rounded-xl p-4">
            <div class="flex items-start justify-between mb-3">
              <div>
                <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wide">Date de l'entrée</p>
                <p class="text-sm font-bold text-gray-900">Hier, 13 Mars 2026 à 20:45</p>
              </div>
              <span class="bg-white border border-gray-200 text-gray-700 text-xs font-medium px-3 py-1 rounded-full whitespace-nowrap">Symptômes : Modérés</span>
            </div>
            <!-- Intensité bar -->
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-medium text-gray-500">Intensité</span>
              <div class="flex-1 h-2 bg-gray-200 rounded-full overflow-hidden">
                <div class="h-full bg-gray-900 rounded-full" style="width:60%"></div>
              </div>
              <span class="text-sm font-bold text-gray-900">6/10</span>
            </div>
            <p class="text-sm text-gray-600 italic">"Légère fatigue après la marche de l'après-midi. Pas de douleur thoracique signalée."</p>
          </div>
        </section>
      </div>

      <!-- ===== COLONNE DROITE (Médicaments) ===== -->
      <div class="lg:col-span-1">
        <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 md:p-6">
          <h2 class="flex items-center gap-2 text-base font-bold text-gray-900 mb-5">
            <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
            Médicaments du jour
          </h2>

          <!-- MATIN -->
          <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wide mb-2">Matin</p>
          <div class="space-y-2 mb-5">
            <label class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl cursor-pointer hover:bg-slate-100 transition-colors">
              <input type="checkbox" checked class="w-4 h-4 rounded border-gray-300 text-gray-900 focus:ring-gray-900">
              <div class="flex-1">
                <p class="text-sm font-bold text-gray-900">Ramipril 5mg</p>
                <p class="text-xs text-gray-400">1 comprimé • 08:00</p>
              </div>
            </label>
            <label class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl cursor-pointer hover:bg-slate-100 transition-colors">
              <input type="checkbox" checked class="w-4 h-4 rounded border-gray-300 text-gray-900 focus:ring-gray-900">
              <div class="flex-1">
                <p class="text-sm font-bold text-gray-900">Bisoprolol 2.5mg</p>
                <p class="text-xs text-gray-400">1 comprimé • 08:00</p>
              </div>
            </label>
          </div>

          <!-- MIDI -->
          <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wide mb-2">Midi</p>
          <div class="space-y-2 mb-5">
            <label class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl cursor-pointer hover:bg-slate-100 transition-colors">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-gray-900 focus:ring-gray-900">
              <div class="flex-1">
                <p class="text-sm font-bold text-gray-900">Complément Fer</p>
                <p class="text-xs text-gray-400">1 gélule • 12:30</p>
              </div>
            </label>
          </div>

          <!-- SOIR -->
          <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wide mb-2">Soir</p>
          <div class="space-y-2 mb-5">
            <label class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl cursor-pointer hover:bg-slate-100 transition-colors">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-gray-900 focus:ring-gray-900">
              <div class="flex-1">
                <p class="text-sm font-bold text-gray-900">Atorvastatine 20mg</p>
                <p class="text-xs text-gray-400">1 comprimé • 20:00</p>
              </div>
            </label>
          </div>

          <!-- Ajouter -->
          <button class="w-full border-2 border-dashed border-gray-200 hover:border-gray-300 text-gray-500 hover:text-gray-700 text-sm font-medium py-3 rounded-xl transition-colors">
            + Ajouter un médicament
          </button>
        </section>
      </div>
    </div>
  </main>

  <!-- ===== BOTTOM NAV (mobile uniquement) ===== -->
  <nav class="md:hidden fixed bottom-0 inset-x-0 bg-white border-t border-gray-200 z-40">
    <div class="grid grid-cols-4">
      <a href="{{ path('app_dashboard') }}" class="flex flex-col items-center gap-1 py-3 text-gray-900">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
        <span class="text-[10px] font-semibold uppercase">Dashboard</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span class="text-[10px] font-medium uppercase">RDV</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
        <span class="text-[10px] font-medium uppercase">Médocs</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        <span class="text-[10px] font-medium uppercase">Journal</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Parcours Santé — Votre parcours de soin, simplifié{% endblock %}

{% block body %}
<div class="min-h-screen bg-white text-gray-900">

 
  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 md:px-8 pt-16 pb-20 md:pt-24 md:pb-28">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Texte -->
        <div>
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 text-gray-600 text-xs font-medium mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-900"></span>
            Conçu pour les patients en oncologie
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight mb-6">
            Votre parcours de soin, <span class="text-gray-400">simplifié</span>
          </h1>
          <p class="text-lg text-gray-500 leading-relaxed mb-8 max-w-lg">
            Centralisez vos rendez-vous, suivez vos médicaments et notez vos symptômes au quotidien. Une application simple et rassurante pour vous accompagner à chaque étape.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <a href="{{ path('app_register') }}" class="inline-flex items-center justify-center gap-2 bg-gray-900 hover:bg-gray-800 text-white font-semibold px-6 py-3.5 rounded-xl transition-colors">
              Commencer gratuitement
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="#comment" class="inline-flex items-center justify-center gap-2 border border-gray-200 hover:border-gray-300 text-gray-700 font-semibold px-6 py-3.5 rounded-xl transition-colors">
              Découvrir
            </a>
          </div>
          <div class="flex items-center gap-6 text-sm text-gray-400">
            <span class="inline-flex items-center gap-1.5"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>100% gratuit</span>
            <span class="inline-flex items-center gap-1.5"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Données sécurisées</span>
            <span class="inline-flex items-center gap-1.5"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Sans installation</span>
          </div>
        </div>

        <!-- Mockup dashboard -->
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-slate-100 to-transparent rounded-3xl -z-10"></div>
          <div class="bg-white rounded-2xl border border-gray-200 shadow-xl overflow-hidden">
            <!-- Barre -->
            <div class="bg-slate-50 px-4 py-3 flex items-center gap-2 border-b border-gray-100">
              <div class="flex gap-1.5"><span class="w-3 h-3 rounded-full bg-gray-300"></span><span class="w-3 h-3 rounded-full bg-gray-300"></span><span class="w-3 h-3 rounded-full bg-gray-300"></span></div>
            </div>
            <div class="p-5">
              <p class="text-lg font-bold mb-1">Bonjour, Marie 👋</p>
              <p class="text-xs text-gray-400 mb-5">Aujourd'hui, 14 Mars 2026</p>
              <!-- RDV -->
              <div class="bg-slate-50 rounded-xl p-3 mb-3 flex items-center gap-3">
                <div class="flex flex-col items-center justify-center w-11 h-12 bg-white rounded-lg border border-gray-100 flex-shrink-0">
                  <span class="text-[9px] font-semibold text-gray-400 uppercase">Mar</span>
                  <span class="text-base font-bold leading-none">15</span>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-bold">Dr. Sophie Martin</p>
                  <p class="text-xs text-gray-400">Cardiologue • 09:30</p>
                </div>
                <span class="text-[9px] font-bold uppercase bg-gray-900 text-white px-2 py-0.5 rounded">RDV</span>
              </div>
              <!-- Médicament -->
              <div class="bg-slate-50 rounded-xl p-3 mb-3 flex items-center gap-3">
                <div class="w-9 h-9 bg-gray-900 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-bold">Ramipril 5mg</p>
                  <p class="text-xs text-gray-400">Matin • 08:00</p>
                </div>
                <span class="text-[9px] font-bold uppercase bg-slate-200 text-gray-600 px-2 py-0.5 rounded">Pris</span>
              </div>
              <!-- Journal -->
              <div class="bg-slate-50 rounded-xl p-3">
                <div class="flex items-center justify-between mb-2">
                  <p class="text-xs font-semibold text-gray-500">Symptômes du jour</p>
                  <span class="text-xs font-bold">4/10</span>
                </div>
                <div class="h-1.5 bg-gray-200 rounded-full overflow-hidden">
                  <div class="h-full bg-gray-900 rounded-full" style="width:40%"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section class="border-y border-gray-100 bg-slate-50">
    <div class="max-w-5xl mx-auto px-4 md:px-8 grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-100">
      <div class="py-8 text-center">
        <p class="text-3xl font-bold">3</p>
        <p class="text-sm text-gray-400 mt-1">modules essentiels</p>
      </div>
      <div class="py-8 text-center">
        <p class="text-3xl font-bold">100%</p>
        <p class="text-sm text-gray-400 mt-1">gratuit</p>
      </div>
      <div class="py-8 text-center">
        <p class="text-3xl font-bold">RGPD</p>
        <p class="text-sm text-gray-400 mt-1">conforme</p>
      </div>
      <div class="py-8 text-center">
        <p class="text-3xl font-bold">24/7</p>
        <p class="text-sm text-gray-400 mt-1">accessible</p>
      </div>
    </div>
  </section>

  <!-- ===== FONCTIONNALITÉS ===== -->
  <section id="fonctionnalites" class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      <div class="max-w-2xl mb-14">
        <span class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3 block">Fonctionnalités</span>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Tout ce dont vous avez besoin, au même endroit</h2>
        <p class="text-lg text-gray-500">Trois modules pensés pour simplifier votre quotidien pendant votre traitement.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-7 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-gray-900 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Gestion des rendez-vous</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Centralisez toutes vos consultations, chimiothérapies et bilans. Retrouvez en un coup d'œil vos rendez-vous à venir et passés.</p>
        </div>
        <!-- Feature 2 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-7 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-gray-900 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Suivi des médicaments</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Enregistrez vos traitements avec dosage et fréquence. Recevez des rappels automatiques et confirmez vos prises quotidiennes.</p>
        </div>
        <!-- Feature 3 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-7 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-gray-900 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3v18h18M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Journal des symptômes</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Notez vos symptômes et leur intensité chaque jour. Visualisez leur évolution sur 30 jours et partagez-la avec votre médecin.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COMMENT ÇA MARCHE ===== -->
  <section id="comment" class="py-20 md:py-28 bg-slate-50 border-y border-gray-100">
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      <div class="max-w-2xl mb-14">
        <span class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3 block">Comment ça marche</span>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Simple à prendre en main</h2>
        <p class="text-lg text-gray-500">Trois étapes pour reprendre le contrôle de votre parcours de soin.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="w-9 h-9 bg-gray-900 text-white rounded-full flex items-center justify-center font-bold text-sm">1</span>
            <div class="flex-1 h-px bg-gray-200 hidden md:block"></div>
          </div>
          <h3 class="text-lg font-bold mb-2">Créez votre compte</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Inscription en 2 minutes. Aucune carte bancaire requise, vos données restent privées.</p>
        </div>
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="w-9 h-9 bg-gray-900 text-white rounded-full flex items-center justify-center font-bold text-sm">2</span>
            <div class="flex-1 h-px bg-gray-200 hidden md:block"></div>
          </div>
          <h3 class="text-lg font-bold mb-2">Ajoutez vos informations</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Rendez-vous, médicaments, symptômes : tout se centralise dans un espace unique.</p>
        </div>
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="w-9 h-9 bg-gray-900 text-white rounded-full flex items-center justify-center font-bold text-sm">3</span>
          </div>
          <h3 class="text-lg font-bold mb-2">Suivez votre évolution</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Visualisez vos données, recevez vos rappels et partagez votre suivi avec votre médecin.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SÉCURITÉ ===== -->
  <section id="securite" class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      <div class="bg-gray-900 rounded-3xl p-8 md:p-14 text-white">
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3 block">Sécurité & confidentialité</span>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Vos données de santé sont protégées</h2>
            <p class="text-gray-300 leading-relaxed mb-6">Les données de santé sont sensibles. Parcours Santé applique les standards les plus stricts pour garantir leur confidentialité et leur sécurité.</p>
          </div>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-white/10 rounded-lg flex items-center justify-center flex-shrink-0"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg></div>
              <div><p class="font-semibold">Conforme au RGPD</p><p class="text-sm text-gray-400">Consentement explicite et droit à l'effacement de vos données.</p></div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-white/10 rounded-lg flex items-center justify-center flex-shrink-0"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg></div>
              <div><p class="font-semibold">Mots de passe chiffrés</p><p class="text-sm text-gray-400">Vos identifiants sont protégés par un chiffrement robuste.</p></div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-white/10 rounded-lg flex items-center justify-center flex-shrink-0"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg></div>
              <div><p class="font-semibold">Accès strictement privé</p><p class="text-sm text-gray-400">Vous seul avez accès à vos informations médicales.</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA FINAL ===== -->
  <section class="pb-20 md:pb-28">
    <div class="max-w-4xl mx-auto px-4 md:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Commencez votre suivi dès aujourd'hui</h2>
      <p class="text-lg text-gray-500 mb-8 max-w-xl mx-auto">Gratuit, sans engagement, accessible depuis n'importe quel appareil.</p>
      <a href="{{ path('app_register') }}" class="inline-flex items-center justify-center gap-2 bg-gray-900 hover:bg-gray-800 text-white font-semibold px-8 py-4 rounded-xl transition-colors">
        Créer mon compte gratuitement
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="border-t border-gray-100 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4 md:px-8 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">
        <div class="col-span-2 md:col-span-1">
          <div class="flex items-center gap-2.5 mb-3">
            <div class="w-8 h-8 bg-gray-900 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            </div>
            <span class="font-bold">Parcours Santé</span>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">Votre parcours de soin, simplifié.</p>
        </div>
        <div>
          <h4 class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-4">Produit</h4>
          <ul class="space-y-2.5">
            <li><a href="#fonctionnalites" class="text-sm text-gray-600 hover:text-gray-900">Fonctionnalités</a></li>
            <li><a href="#comment" class="text-sm text-gray-600 hover:text-gray-900">Comment ça marche</a></li>
            <li><a href="#securite" class="text-sm text-gray-600 hover:text-gray-900">Sécurité</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-4">Légal</h4>
          <ul class="space-y-2.5">
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900">Mentions légales</a></li>
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900">Confidentialité</a></li>
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900">RGPD</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-4">Contact</h4>
          <ul class="space-y-2.5">
            <li><a href="mailto:contact@parcours-sante.fr" class="text-sm text-gray-600 hover:text-gray-900">contact@parcours-sante.fr</a></li>
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900">À propos</a></li>
          </ul>
        </div>
      </div>
      <div class="pt-8 border-t border-gray-200 text-center">
        <p class="text-xs text-gray-400">© 2026 Parcours Santé. Tous droits réservés.</p>
      </div>
    </div>
  </footer>
</div>

<script>
document.getElementById('burger').addEventListener('click', function() {
  document.getElementById('mobileNav').classList.toggle('hidden');
});
document.querySelectorAll('#mobileNav a').forEach(function(a) {
  a.addEventListener('click', function() {
    document.getElementById('mobileNav').classList.add('hidden');
  });
});
</script>
{% endblock %}
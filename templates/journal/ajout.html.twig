{% extends 'base.html.twig' %}

{% block title %}Nouvelle entrée — Parcours Santé{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 flex flex-col pb-32 md:pb-0">

  <!-- ===== MAIN ===== -->
  <main class="flex-1 max-w-3xl w-full mx-auto px-4 md:px-8 py-6 md:py-8">

    <!-- Retour (desktop) -->
    <a href="{{ path('app_journal') }}" class="hidden md:inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-gray-900 mb-6 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Retour au journal
    </a>

    <!-- Titre mobile (hors carte) -->
    <div class="md:hidden mb-6">
      <h1 class="text-3xl font-bold text-gray-900 mb-1">Nouvelle entrée</h1>
      <p class="text-gray-500 text-sm">Notez comment vous vous sentez aujourd'hui.</p>
    </div>

    <!-- Carte formulaire -->
    <div class="bg-white md:rounded-2xl md:border border-gray-100 md:shadow-sm md:p-8">

      <!-- Titre desktop (dans la carte) -->
      <div class="hidden md:block mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-1">Nouvelle entrée</h1>
        <p class="text-gray-500 text-sm">Notez votre symptôme et son intensité pour suivre votre évolution.</p>
      </div>

      {{ form_start(journalType, {'attr': {'class': 'space-y-6', 'id': 'journal-form'}}) }}

        <!-- Date -->
        <div>
          {{ form_label(journalType.date, 'Date de l\'entrée', {'label_attr': {'class': 'block text-sm font-semibold text-gray-900 mb-2'}}) }}
          {{ form_widget(journalType.date, {'attr': {
            'class': 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all text-gray-700'
          }}) }}
          {{ form_errors(journalType.date) }}
        </div>

        <!-- Symptôme -->
        <div>
          {{ form_label(journalType.symptome, 'Symptôme', {'label_attr': {'class': 'block text-sm font-semibold text-gray-900 mb-2'}}) }}
          <div class="relative">
            {{ form_widget(journalType.symptome, {'attr': {
              'class': 'w-full appearance-none px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all text-gray-700 bg-white cursor-pointer'
            }}) }}
            <svg class="absolute right-4 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </div>
          {{ form_errors(journalType.symptome) }}
        </div>

        <!-- Intensité (curseur) -->
        <div>
          <div class="flex items-center justify-between mb-2">
            {{ form_label(journalType.intensite, 'Intensité', {'label_attr': {'class': 'block text-sm font-semibold text-gray-900'}}) }}
            <span class="inline-flex items-baseline gap-0.5">
              <span id="intensite-value" class="text-2xl font-bold text-gray-900">5</span>
              <span class="text-sm text-gray-400">/10</span>
            </span>
          </div>
          {{ form_widget(journalType.intensite, {'attr': {
            'class': 'w-full accent-gray-900 cursor-pointer',
            'min': 1,
            'max': 10,
            'step': 1,
            'value': 5,
            'oninput': 'document.getElementById("intensite-value").textContent = this.value; updateIntensiteColor(this.value);'
          }}) }}
          <!-- Échelle repères -->
          <div class="flex justify-between text-[10px] text-gray-400 mt-1 px-0.5">
            <span>1</span><span>2</span><span>3</span><span>4</span><span>5</span>
            <span>6</span><span>7</span><span>8</span><span>9</span><span>10</span>
          </div>
          <!-- Indicateur textuel -->
          <p id="intensite-label" class="text-xs font-medium mt-2 text-orange-500">Intensité modérée</p>
          {{ form_errors(journalType.intensite) }}
        </div>

        <!-- Note libre (si ton entité a un champ note, sinon supprime ce bloc) -->
        {% if journalType.note is defined %}
        <div>
          {{ form_label(journalType.note, 'Note', {'label_attr': {'class': 'block text-sm font-semibold text-gray-900 mb-2'}}) }}
          {{ form_widget(journalType.note, {'attr': {
            'class': 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all placeholder:text-gray-400 resize-none',
            'placeholder': 'Décrivez comment vous vous sentez, le contexte, ce qui a aidé...',
            'rows': 4
          }}) }}
          {{ form_errors(journalType.note) }}
        </div>
        {% endif %}

        <!-- Actions (desktop) -->
        <div class="hidden md:flex items-center justify-end gap-3 pt-6 border-t border-gray-100">
          <a href="{{ path('app_journal') }}" class="text-sm font-medium text-gray-700 border border-gray-200 hover:border-gray-300 px-6 py-3 rounded-lg transition-colors">Annuler</a>
          <button type="submit" class="text-sm font-semibold text-white bg-gray-900 hover:bg-gray-800 px-6 py-3 rounded-lg transition-colors">Enregistrer</button>
        </div>

      {{ form_end(journalType) }}
    </div>

    <!-- Bloc info (desktop) -->
    <div class="hidden md:flex items-start gap-4 mt-6 p-5 border-2 border-dashed border-gray-200 rounded-2xl">
      <div class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <div>
        <p class="text-sm font-bold text-gray-900 mb-1">Pourquoi tenir un journal ?</p>
        <p class="text-xs text-gray-500">Noter vos symptômes régulièrement permet de visualiser leur évolution et d'en discuter précisément avec votre médecin lors de vos consultations.</p>
      </div>
    </div>
  </main>

  <!-- ===== ACTIONS FIXES (mobile) ===== -->
  <div class="md:hidden fixed bottom-0 inset-x-0 bg-white border-t border-gray-200 px-4 py-3 z-40 space-y-2">
    <button type="submit" form="journal-form" class="w-full bg-gray-900 hover:bg-gray-800 text-white font-semibold py-4 rounded-xl transition-colors">Enregistrer l'entrée</button>
    <a href="{{ path('app_journal') }}" class="block text-center text-sm font-medium text-gray-500 hover:text-gray-900 py-2">Annuler</a>
  </div>

</div>

<script>
function updateIntensiteColor(value) {
  const label = document.getElementById('intensite-label');
  const num = parseInt(value);
  if (num <= 3) {
    label.textContent = 'Intensité faible';
    label.className = 'text-xs font-medium mt-2 text-green-500';
  } else if (num <= 6) {
    label.textContent = 'Intensité modérée';
    label.className = 'text-xs font-medium mt-2 text-orange-500';
  } else {
    label.textContent = 'Intensité élevée';
    label.className = 'text-xs font-medium mt-2 text-red-500';
  }
}
</script>
{% endblock %}
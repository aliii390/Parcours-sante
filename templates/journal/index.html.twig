{% extends 'base.html.twig' %}

{% block title %}Mon journal — Parcours Santé{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 flex flex-col pb-20 md:pb-0">

  

  <!-- ===== MAIN ===== -->
  <main class="flex-1 max-w-5xl w-full mx-auto px-4 md:px-8 py-8">

    <!-- Titre + bouton -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-1">Mon journal</h1>
        <p class="text-gray-500 text-sm md:text-base">Suivez l'évolution de vos symptômes au quotidien.</p>
      </div>
      <a href="#" class="inline-flex items-center justify-center gap-2 bg-gray-900 hover:bg-gray-800 text-white font-semibold px-5 py-3 rounded-xl transition-colors whitespace-nowrap">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nouvelle entrée
      </a>
    </div>

    <!-- GRAPHIQUE -->
    <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 md:p-6 mb-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-base font-bold text-gray-900">Intensité des symptômes (30 derniers jours)</h2>
        <span class="inline-flex items-center gap-2 text-xs font-medium text-gray-500">
          <span class="w-2.5 h-2.5 rounded-full bg-gray-900"></span>Intensité
        </span>
      </div>
      <div class="relative w-full" style="height:300px">
        <canvas id="symptomesChart"></canvas>
      </div>
    </section>

    <!-- HISTORIQUE -->
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold text-gray-900">Historique des entrées</h2>
      <button class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 border border-gray-200 hover:border-gray-300 px-3 py-2 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
        Filtrer
      </button>
    </div>

    <div class="space-y-3">

      <!-- Entrée 1 -->
      <a href="#" class="block bg-white rounded-2xl border border-gray-100 shadow-sm p-4 md:p-5 hover:border-gray-200 transition-colors">
        <div class="flex items-start gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-2">
              <div>
                <p class="text-sm font-bold text-gray-900">14 Mars 2026</p>
                <p class="text-xs text-gray-400">20:45</p>
              </div>
              <div class="flex flex-wrap gap-1.5">
                <span class="text-xs font-medium bg-slate-100 text-gray-700 px-2.5 py-1 rounded-lg">Fatigue</span>
                <span class="text-xs font-medium bg-slate-100 text-gray-700 px-2.5 py-1 rounded-lg">Maux de tête</span>
              </div>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed">Légère fatigue après la marche de l'après-midi. Pas de douleur thoracique signalée, mais une tension aux tempes vers 18h.</p>
          </div>
          <div class="flex items-center gap-3 flex-shrink-0">
            <div class="text-right">
              <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wide">Intensité</p>
              <p class="text-xl font-bold text-gray-900">6<span class="text-xs text-gray-400 font-normal">/10</span></p>
            </div>
            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

      <!-- Entrée 2 -->
      <a href="#" class="block bg-white rounded-2xl border border-gray-100 shadow-sm p-4 md:p-5 hover:border-gray-200 transition-colors">
        <div class="flex items-start gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-2">
              <div>
                <p class="text-sm font-bold text-gray-900">11 Mars 2026</p>
                <p class="text-xs text-gray-400">09:15</p>
              </div>
              <div class="flex flex-wrap gap-1.5">
                <span class="text-xs font-medium bg-slate-100 text-gray-700 px-2.5 py-1 rounded-lg">Nausée</span>
              </div>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed">Sensation de nausée passagère au réveil. S'est dissipée après le petit-déjeuner et la prise des médicaments.</p>
          </div>
          <div class="flex items-center gap-3 flex-shrink-0">
            <div class="text-right">
              <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wide">Intensité</p>
              <p class="text-xl font-bold text-gray-900">5<span class="text-xs text-gray-400 font-normal">/10</span></p>
            </div>
            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

      <!-- Entrée 3 -->
      <a href="#" class="block bg-white rounded-2xl border border-gray-100 shadow-sm p-4 md:p-5 hover:border-gray-200 transition-colors">
        <div class="flex items-start gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-2">
              <div>
                <p class="text-sm font-bold text-gray-900">08 Mars 2026</p>
                <p class="text-xs text-gray-400">14:30</p>
              </div>
              <div class="flex flex-wrap gap-1.5">
                <span class="text-xs font-medium bg-slate-100 text-gray-700 px-2.5 py-1 rounded-lg">Palpitations</span>
              </div>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed">Légères palpitations pendant environ 5 minutes. Repos immédiat assis, retour à la normale rapide.</p>
          </div>
          <div class="flex items-center gap-3 flex-shrink-0">
            <div class="text-right">
              <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wide">Intensité</p>
              <p class="text-xl font-bold text-gray-900">3<span class="text-xs text-gray-400 font-normal">/10</span></p>
            </div>
            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

      <!-- Entrée 4 -->
      <a href="#" class="block bg-white rounded-2xl border border-gray-100 shadow-sm p-4 md:p-5 hover:border-gray-200 transition-colors">
        <div class="flex items-start gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-2">
              <div>
                <p class="text-sm font-bold text-gray-900">05 Mars 2026</p>
                <p class="text-xs text-gray-400">21:00</p>
              </div>
              <div class="flex flex-wrap gap-1.5">
                <span class="text-xs font-medium bg-slate-100 text-gray-700 px-2.5 py-1 rounded-lg">Fatigue</span>
                <span class="text-xs font-medium bg-slate-100 text-gray-700 px-2.5 py-1 rounded-lg">Essoufflement</span>
              </div>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed">Essoufflement plus marqué que d'habitude lors de la montée des escaliers. Nécessité de faire une pause.</p>
          </div>
          <div class="flex items-center gap-3 flex-shrink-0">
            <div class="text-right">
              <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wide">Intensité</p>
              <p class="text-xl font-bold text-gray-900">6<span class="text-xs text-gray-400 font-normal">/10</span></p>
            </div>
            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

    </div>

    <!-- Charger plus -->
    <div class="text-center mt-8">
      <button class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 border border-gray-200 hover:border-gray-300 px-5 py-2.5 rounded-lg transition-colors">
        Charger plus d'entrées
      </button>
    </div>
  </main>

  

  <!-- ===== BOTTOM NAV (mobile) ===== -->
  <nav class="md:hidden fixed bottom-0 inset-x-0 bg-white border-t border-gray-200 z-40">
    <div class="grid grid-cols-4">
      <a href="{{ path('app_dashboard') }}" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 13l2-2m0 0l7-7 7 7M5 11v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <span class="text-[10px] font-medium">Dashboard</span>
      </a>
      <a href="{{ path('app_rendez_vous') }}" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span class="text-[10px] font-medium">Rendez-vous</span>
      </a>
      <a href="{{ path('app_medicament') }}" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
        <span class="text-[10px] font-medium">Médicaments</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 py-3 text-gray-900">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        <span class="text-[10px] font-medium">Journal</span>
      </a>
    </div>
  </nav>
</div>

<!-- Chart.js via CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  const ctx = document.getElementById('symptomesChart');
  if (!ctx) return;

  new Chart(ctx, {
    type: 'line',
    data: {
      labels: ['15 Fév','18 Fév','21 Fév','24 Fév','27 Fév','02 Mar','05 Mar','08 Mar','11 Mar','14 Mar'],
      datasets: [{
        label: 'Intensité',
        data: [2, 4, 3, 7, 5, 4, 6, 3, 5, 6],
        borderColor: '#111827',
        backgroundColor: '#111827',
        borderWidth: 2,
        pointRadius: 4,
        pointBackgroundColor: '#111827',
        tension: 0.3,
        fill: false
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        y: {
          beginAtZero: true,
          max: 10,
          ticks: { stepSize: 2, color: '#9CA3AF' },
          grid: { color: '#F3F4F6' }
        },
        x: {
          ticks: { color: '#9CA3AF' },
          grid: { display: false }
        }
      }
    }
  });
});
</script>
{% endblock %}
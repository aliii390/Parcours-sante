{% extends 'base.html.twig' %}

{% block title %}Mes médicaments — Parcours Santé{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 flex flex-col pb-20 md:pb-0">

  <!-- ===== MAIN ===== -->
  <main class="flex-1 max-w-7xl w-full mx-auto px-4 md:px-8 py-8">

    <!-- Titre + bouton -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-1">Mes médicaments</h1>
        <p class="text-gray-500 text-sm md:text-base hidden md:block">Gérez vos traitements et vos ordonnances en cours.</p>
      </div>
      <a href="{{ path('app_ajout_medicament')}}" class="inline-flex items-center justify-center gap-2 bg-gray-900 hover:bg-gray-800 text-white font-semibold px-5 py-3 rounded-xl transition-colors whitespace-nowrap">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Ajouter un médicament
      </a>
    </div>

    <!-- Recherche + toggle -->
<div class="flex flex-col md:flex-row md:items-center gap-3 mb-8">
  <div class="relative flex-1">
    <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    <input type="text" id="recherche-medicament" placeholder="Rechercher un médicament..." class="w-full pl-9 pr-4 py-3 text-sm bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
  </div>
  <label class="flex items-center justify-between md:justify-end gap-3 cursor-pointer">
    <span class="text-sm text-gray-600">Afficher uniquement les médicaments actifs</span>
    <div class="relative">
      <input type="checkbox" id="toggle-actifs" checked class="sr-only peer">
      <div class="w-11 h-6 bg-gray-200 rounded-full peer peer-checked:bg-gray-900 transition-colors"></div>
      <div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
    </div>
  </label>
</div>

    <!-- Grille médicaments -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">

 {% for medicament in medicaments %}
  <div class="medicament-card bg-white rounded-2xl border border-gray-100 shadow-sm p-5 flex flex-col {{ medicament.actif ? '' : 'opacity-70' }}"
       data-actif="{{ medicament.actif ? '1' : '0' }}"
       data-nom="{{ medicament.nom|lower }}">

    <div class="flex items-start justify-between mb-4">
      <div class="w-11 h-11 bg-slate-100 rounded-xl flex items-center justify-center">
        <svg class="w-5 h-5 {{ medicament.actif ? 'text-gray-500' : 'text-gray-400' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
        </svg>
      </div>

      {% if medicament.actif %}
        <span class="text-[10px] font-bold uppercase tracking-wide bg-gray-900 text-white px-2.5 py-1 rounded">Actif</span>
      {% else %}
        <span class="text-[10px] font-bold uppercase tracking-wide bg-gray-200 text-gray-500 px-2.5 py-1 rounded">Inactif</span>
      {% endif %}
    </div>

    <h3 class="text-lg font-bold text-gray-900">{{ medicament.nom }}</h3>
    <p class="text-sm text-gray-500 mb-4">Dosage : {{ medicament.dosage }}</p>

    <div class="space-y-2 mb-5 pt-4 border-t border-gray-100">
      <div class="flex items-center gap-2 text-sm text-gray-600">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Début : <span class="font-semibold text-gray-900">{{ medicament.dateDebut ? medicament.dateDebut|date('d/m/Y') : '—' }}</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-gray-600">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="9" stroke-width="2"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 7v5l3 2"/>
        </svg>
        Fin : <span class="font-semibold text-gray-900">{{ medicament.dateFin ? medicament.dateFin|date('d/m/Y') : '—' }}</span>
      </div>
    </div>

    <a href="#" class="mt-auto block text-center text-sm font-medium {{ medicament.actif ? 'text-gray-700' : 'text-gray-500' }} border border-gray-200 hover:border-gray-300 py-2.5 rounded-lg transition-colors">
      Modifier
    </a>

  </div>
{% else %}
  <p class="col-span-full text-sm text-gray-500">Aucun médicament enregistré pour le moment.</p>
{% endfor %}

  <!-- Ajouter un nouveau médicament (hors boucle) -->
  <a href="#" class="border-2 border-dashed border-gray-200 hover:border-gray-300 rounded-2xl p-5 flex flex-col items-center justify-center text-center min-h-[240px] transition-colors group">
    <div class="w-12 h-12 bg-slate-100 group-hover:bg-slate-200 rounded-full flex items-center justify-center mb-3 transition-colors">
      <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
    </div>
    <span class="text-sm font-medium text-gray-500">Ajouter un nouveau médicament</span>
  </a>

</div>
  </main>

  

  <!-- ===== BOTTOM NAV (mobile) ===== -->
  <nav class="md:hidden fixed bottom-0 inset-x-0 bg-white border-t border-gray-200 z-40">
    <div class="grid grid-cols-4">
      <a href="{{ path('app_dashboard') }}" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 13l2-2m0 0l7-7 7 7M5 11v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <span class="text-[10px] font-medium">Dashboard</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span class="text-[10px] font-medium">Rendez-vous</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 py-3 text-gray-900">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
        <span class="text-[10px] font-semibold">Médicaments</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        <span class="text-[10px] font-medium">Journal</span>
      </a>
    </div>
  </nav>
</div>




<script>
document.addEventListener('DOMContentLoaded', function () {
  const toggle = document.getElementById('toggle-actifs');
  const recherche = document.getElementById('recherche-medicament');
  const cards = document.querySelectorAll('.medicament-card');

  function filtrer() {
    const actifsSeuls = toggle.checked;
    const terme = recherche.value.trim().toLowerCase();

    cards.forEach(function (card) {
      const estActif = card.dataset.actif === '1';
      const nom = card.dataset.nom || '';

      // Condition 1 : filtre actif/inactif
      const passeActif = !actifsSeuls || estActif;
      // Condition 2 : filtre recherche
      const passeRecherche = terme === '' || nom.includes(terme);

      // La carte s'affiche seulement si elle passe les deux filtres
      card.style.display = (passeActif && passeRecherche) ? '' : 'none';
    });
  }

  toggle.addEventListener('change', filtrer);
  recherche.addEventListener('input', filtrer);
  filtrer(); // applique dès le chargement (toggle coché = actifs seuls)
});
</script>

{% endblock %}
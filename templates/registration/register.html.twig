{% extends 'base.html.twig' %}

{% block title %}Inscription — Parcours Santé{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 flex flex-col">



  <!-- Main content -->
  <div class="flex-1 flex items-center justify-center px-4 pb-12 md:pb-0">
    <div class="w-full max-w-md">
      <!-- Card form -->
      <div class="bg-white rounded-2xl shadow-lg p-6 md:p-8">
        <div class="mb-8 text-center md:text-left">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">Créer un compte</h2>
          <p class="text-gray-500 text-sm md:text-base">Rejoignez Parcours Santé et prenez le contrôle de votre suivi de soin.</p>
        </div>

        {{ form_start(registrationForm, {'attr': {'class': 'space-y-5', 'novalidate': 'novalidate'}}) }}

          <!-- Global form errors -->
          {% if registrationForm.vars.errors|length > 0 %}
            <div class="bg-red-50 border border-red-200 rounded-lg p-4">
              {% for error in registrationForm.vars.errors %}
                <p class="text-red-700 text-sm font-medium">{{ error.message }}</p>
              {% endfor %}
            </div>
          {% endif %}

          <!-- Prénom field -->
          <div>
            <label for="{{ registrationForm.prenom.vars.id }}" class="block text-sm font-semibold text-gray-900 mb-2">Prénom</label>
            {% if registrationForm.prenom.vars.errors|length > 0 %}
              <div class="relative">
                {{ form_widget(registrationForm.prenom, {'attr': {'class': 'w-full px-4 py-3 border-2 border-red-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-all', 'placeholder': 'Jean'}}) }}
              </div>
              {% for error in registrationForm.prenom.vars.errors %}
                <p class="text-red-600 text-xs mt-1">{{ error.message }}</p>
              {% endfor %}
            {% else %}
              <div class="relative">
                {{ form_widget(registrationForm.prenom, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all', 'placeholder': 'Jean'}}) }}
              </div>
            {% endif %}
          </div>

          <!-- Nom field -->
          <div>
            <label for="{{ registrationForm.nom.vars.id }}" class="block text-sm font-semibold text-gray-900 mb-2">Nom</label>
            {% if registrationForm.nom.vars.errors|length > 0 %}
              <div class="relative">
                {{ form_widget(registrationForm.nom, {'attr': {'class': 'w-full px-4 py-3 border-2 border-red-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-all', 'placeholder': 'Dupont'}}) }}
              </div>
              {% for error in registrationForm.nom.vars.errors %}
                <p class="text-red-600 text-xs mt-1">{{ error.message }}</p>
              {% endfor %}
            {% else %}
              <div class="relative">
                {{ form_widget(registrationForm.nom, {'attr': {'class': 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all', 'placeholder': 'Dupont'}}) }}
              </div>
            {% endif %}
          </div>

          <!-- Email field -->
          <div>
            <label for="{{ registrationForm.email.vars.id }}" class="block text-sm font-semibold text-gray-900 mb-2">Adresse e-mail</label>
            {% if registrationForm.email.vars.errors|length > 0 %}
              <div class="relative">
                <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full pl-10 pr-4 py-3 border-2 border-red-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-all', 'placeholder': 'nom@example.fr'}}) }}
              </div>
              {% for error in registrationForm.email.vars.errors %}
                <p class="text-red-600 text-xs mt-1">{{ error.message }}</p>
              {% endfor %}
            {% else %}
              <div class="relative">
                <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all', 'placeholder': 'nom@example.fr'}}) }}
              </div>
            {% endif %}
          </div>

          <!-- Password field -->
          <div>
            <label for="{{ registrationForm.plainPassword.vars.id }}" class="block text-sm font-semibold text-gray-900 mb-2">Mot de passe</label>
            {% if registrationForm.plainPassword.vars.errors|length > 0 %}
              <div class="relative">
                <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full pl-10 pr-10 py-3 border-2 border-red-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-all', 'placeholder': '••••••••'}}) }}
                <button 
                  type="button" 
                  class="absolute right-3 top-1/2 transform -translate-y-1/2 text-red-400 hover:text-red-600"
                  onclick="togglePassword('{{ registrationForm.plainPassword.vars.id }}')"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                </button>
              </div>
              {% for error in registrationForm.plainPassword.vars.errors %}
                <p class="text-red-600 text-xs mt-1">{{ error.message }}</p>
              {% endfor %}
            {% else %}
              <div class="relative">
                <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full pl-10 pr-10 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all', 'placeholder': '••••••••'}}) }}
                <button 
                  type="button" 
                  class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-600"
                  onclick="togglePassword('{{ registrationForm.plainPassword.vars.id }}')"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                </button>
              </div>
            {% endif %}
          </div>

          <!-- Terms checkbox -->
          <div class="flex items-start gap-3">
            <div class="flex items-center h-6">
              {% if registrationForm.agreeTerms.vars.errors|length > 0 %}
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-4 h-4 rounded border-red-300 text-red-600 focus:ring-red-500 cursor-pointer'}}) }}
              {% else %}
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500 cursor-pointer'}}) }}
              {% endif %}
            </div>
            <div class="flex-1">
              <label for="{{ registrationForm.agreeTerms.vars.id }}" class="text-sm text-gray-600 cursor-pointer">
                J'accepte les <a href="#" class="text-blue-600 hover:underline font-medium">conditions d'utilisation</a> et la <a href="#" class="text-blue-600 hover:underline font-medium">politique de confidentialité</a>
              </label>
              {% if registrationForm.agreeTerms.vars.errors|length > 0 %}
                {% for error in registrationForm.agreeTerms.vars.errors %}
                  <p class="text-red-600 text-xs mt-1">{{ error.message }}</p>
                {% endfor %}
              {% endif %}
            </div>
          </div>

          <!-- Submit button -->
          <button 
            type="submit" 
            class="w-full bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 text-white font-bold py-3 rounded-lg transition-all duration-200 transform hover:scale-105 active:scale-95 flex items-center justify-center gap-2 mt-8"
          >
            Créer mon compte
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </button>
        {{ form_end(registrationForm) }}

        <!-- Sign in link -->
        <div class="mt-8 pt-8 border-t border-gray-200 text-center">
          <p class="text-sm text-gray-600 mb-3">Vous avez déjà un compte ?</p>
          <a 
            href="{{ path('app_login') }}" 
            class="text-blue-600 hover:text-blue-700 font-semibold underline"
          >
            Se connecter
          </a>
        </div>
      </div>
    </div>
  </div>


</div>

<script>
function togglePassword(inputId) {
  const input = document.getElementById(inputId);
  input.type = input.type === 'password' ? 'text' : 'password';
}
</script>
{% endblock %}
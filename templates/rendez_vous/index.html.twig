{% extends 'base.html.twig' %}

{% block title %}Mes rendez-vous — Parcours Santé{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 flex flex-col pb-20 md:pb-0">

  
  <!-- ===== MAIN ===== -->
  <main class="flex-1 max-w-5xl w-full mx-auto px-4 md:px-8 py-8">

    <!-- Titre + bouton -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-1">Mes rendez-vous</h1>
        <p class="text-gray-500 text-sm md:text-base">Gérez vos consultations médicales et examens à venir.</p>
      </div>
      <a href="{{path('ajout_rendez_vous')}}" class="inline-flex items-center justify-center gap-2 bg-gray-900 hover:bg-gray-800 text-white font-semibold px-5 py-3 rounded-xl transition-colors whitespace-nowrap">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Ajouter un rendez-vous
      </a>
    </div>

    <!-- Onglets + recherche -->
    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-4 mb-6">
      <!-- Tabs -->
      <div class="flex items-center gap-6 border-b border-gray-200 md:border-none">
        <button class="text-sm font-semibold text-gray-900 border-b-2 border-gray-900 pb-3 md:pb-0">À venir ({{nombreRdv}})</button>
        <button class="text-sm font-medium text-gray-400 hover:text-gray-700 pb-3 md:pb-0">Passés</button>
      </div>
      <!-- Recherche -->
      <div class="flex items-center gap-2">
        <div class="relative flex-1 md:w-64">
          <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input type="text" placeholder="Rechercher un médecin..." class="w-full pl-9 pr-4 py-2.5 text-sm bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
        </div>
        <button class="p-2.5 bg-white border border-gray-200 rounded-lg text-gray-500 hover:text-gray-700 hover:border-gray-300 transition-colors" aria-label="Filtres">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
        </button>
      </div>
    </div>

    <!-- ===== MARS 2026 ===== -->
    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Mars 2026</p>
    <div class="space-y-3 mb-8">

      <!-- RDV 1 -->
      {% for rdv in rendezVous %}
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 md:p-5">
        <div class="flex items-start gap-4">
          <div class="flex flex-col items-center justify-center w-14 h-16 bg-slate-100 rounded-lg flex-shrink-0">
            <span class="text-[10px] font-semibold text-gray-400 uppercase">Mar</span>
            <span class="text-xl font-bold text-gray-900 leading-none">15</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <h3 class="text-base font-bold text-gray-900">{{ rdv.titre}}</h3>
              <span class="text-[10px] font-semibold uppercase tracking-wide bg-slate-100 text-gray-600 px-2 py-0.5 rounded">{{rdv.category.nom}}</span>
            </div>
            <div class="flex flex-col sm:flex-row sm:flex-wrap gap-1.5 sm:gap-4 text-xs text-gray-500">
              <span class="inline-flex items-center gap-1.5"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" stroke-width="2"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 7v5l3 2"/></svg>{{rdv.date|date('d/m/Y à H:i')}}</span>
              <span class="inline-flex items-center gap-1.5"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>{{rdv.medecin}}</span>
              <span class="inline-flex items-center gap-1.5"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><circle cx="12" cy="11" r="3" stroke-width="2"/></svg>{{rdv.lieu}}</span>
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <a href="#" class="text-sm font-medium text-gray-700 border border-gray-200 hover:border-gray-300 px-4 py-2 rounded-lg transition-colors">Modifier</a>
            <button class="p-2 text-gray-400 hover:text-gray-600" aria-label="Plus d'options">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
            </button>
          </div>
        </div>
      </div>
      {% endfor %}




    

 

    <!-- Charger plus -->
    <div class="text-center">
      <button class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">
        Charger plus de rendez-vous
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
    </div>
  </main>

  

  <!-- ===== BOTTOM NAV (mobile) ===== -->
  <nav class="md:hidden fixed bottom-0 inset-x-0 bg-white border-t border-gray-200 z-40">
    <div class="grid grid-cols-4">
      <a href="{{ path('app_dashboard') }}" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <span class="text-[10px] font-medium uppercase">Accueil</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 py-3 text-gray-900">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span class="text-[10px] font-semibold uppercase">Rendez-vous</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
        <span class="text-[10px] font-medium uppercase">Traitements</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 py-3 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        <span class="text-[10px] font-medium uppercase">Journal</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}